REDIS_URL=redis://localhost:6379
QUEUE_NAME=tasks
WORKER_CONCURRENCY=1
AI_GATEWAY_API_KEY=
E2B_API_KEY=
MODEL=anthropic/claude-opus-4-7
MAX_LOOP_STEPS=20

# Hono API base URL (used to fetch decrypted GitHub tokens). Inside docker
# compose, set to http://hono-api:3001 or whatever the service name is.
HONO_API_URL=http://localhost:3001

# Shared secret used to authenticate against /api/internal/github-token.
# MUST match WORKER_SHARED_SECRET in the Hono API's environment.
WORKER_SHARED_SECRET=
