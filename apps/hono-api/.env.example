# 32 raw bytes, base64-encoded. Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# GitHub OAuth App credentials (https://github.com/settings/developers)
# The OAuth App's "Authorization callback URL" must be
# http://localhost:3001/api/user/callback/github for local dev.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Pipecat
PIPECAT_SHARED_SECRET=

# Public
PUBLIC_API_URL=http://localhost:3001
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_PIPECAT_WS_URL=ws://localhost:8000/ws

# Redis (BullMQ task queue)
REDIS_URL=redis://localhost:6379
